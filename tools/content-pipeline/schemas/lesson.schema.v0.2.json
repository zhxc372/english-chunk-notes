{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://english-chunk-notes.local/schemas/lesson.v0.2.json",
  "title": "English Chunk Notes Lesson v0.2",
  "type": "object",
  "required": [
    "id",
    "title",
    "level",
    "source",
    "chunks",
    "reviewStatus"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string"
    },
    "level": {
      "enum": [
        "A2",
        "B1",
        "B2",
        "C1"
      ]
    },
    "summaryEn": {
      "type": "string"
    },
    "summaryZh": {
      "type": "string"
    },
    "topicTags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "examTags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "useCaseTags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reviewStatus": {
      "enum": [
        "draft",
        "reviewed",
        "published",
        "rejected"
      ]
    },
    "source": {
      "type": "object",
      "required": [
        "type",
        "url",
        "name",
        "usagePolicy",
        "fetchedAt"
      ],
      "properties": {
        "type": {
          "enum": [
            "web",
            "manual",
            "public_domain",
            "open_license"
          ]
        },
        "url": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "publishedAt": {
          "type": "string"
        },
        "fetchedAt": {
          "type": "string"
        },
        "license": {
          "type": "string"
        },
        "usagePolicy": {
          "enum": [
            "full_text_allowed",
            "summary_chunks_only",
            "metadata_only"
          ]
        },
        "attribution": {
          "type": "string"
        }
      }
    },
    "article": {
      "type": "object",
      "properties": {
        "mode": {
          "enum": [
            "original_allowed",
            "teaching_rewrite",
            "summary_only"
          ]
        },
        "originalText": {
          "type": "string"
        },
        "teachingTextEn": {
          "type": "string"
        },
        "teachingTextZh": {
          "type": "string"
        }
      }
    },
    "chunks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "chunk",
          "meaningZh",
          "example",
          "difficulty",
          "tags"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "chunk": {
            "type": "string"
          },
          "chunkType": {
            "type": "string"
          },
          "difficulty": {
            "enum": [
              "A2",
              "B1",
              "B2",
              "C1"
            ]
          },
          "meaningZh": {
            "type": "string"
          },
          "literalZh": {
            "type": "string"
          },
          "usageNoteZh": {
            "type": "string"
          },
          "sourceSentence": {
            "type": "string"
          },
          "example": {
            "type": "string"
          },
          "examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "cloze": {
            "type": "object",
            "properties": {
              "question": {
                "type": "string"
              },
              "answer": {
                "type": "string"
              }
            }
          },
          "retellPrompt": {
            "type": "string"
          },
          "writingPrompt": {
            "type": "string"
          },
          "audio": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
